<!DOCTYPE html>
<html lang="pt">

<head>
  <link rel="icon" href="../favicon.png" type="image/png" />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Downloads — Luiz Passaroni</title>
  <meta name="description" content="Arquivos disponibilizados por Luiz Passaroni.">
  <meta name="color-scheme" content="light dark">
  <link rel="stylesheet" href="../style.css">

  <style>
    .ios-widget-glass {
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.1) !important;
      border-radius: 1.5rem !important;
      background: rgba(255, 255, 255, 0.7);
      overflow: hidden;
    }

    @media (prefers-color-scheme: dark) {
      .ios-widget-glass {
        background: rgba(28, 28, 30, 0.75) !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
      }
    }

    .dl-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s ease;
    }

    .dl-item:last-child {
      border-bottom: none;
    }

    .dl-item:active {
      background: rgba(0,0,0,0.04);
    }

    @media (prefers-color-scheme: dark) {
      .dl-item:active {
        background: rgba(255,255,255,0.05);
      }
    }

    .dl-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .dl-info { flex: 1; min-width: 0; }

    .dl-name {
      font-size: 15px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .dl-meta {
      font-size: 12px;
      margin-top: 2px;
      opacity: 0.5;
    }

    .dl-right {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .dl-arrow {
      width: 18px;
      height: 18px;
      opacity: 0.35;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 15px;
      font-weight: 500;
      color: var(--ios-blue, #007AFF);
      text-decoration: none;
      padding: 6px 0;
      opacity: 0.9;
      transition: opacity 0.15s;
    }

    .back-btn:active { opacity: 0.6; }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 24px;
      gap: 12px;
      opacity: 0.4;
    }

    .empty-icon {
      width: 52px;
      height: 52px;
    }

    .empty-text {
      font-size: 15px;
      font-weight: 500;
      text-align: center;
    }

    .section-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .category-label {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.45;
      padding-left: 6px;
    }
  </style>
</head>

<body class="min-h-screen">
