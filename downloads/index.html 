<!DOCTYPE html>
<html lang="pt">

<head>
  <link rel="icon" href="../favicon.png" type="image/png" />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Downloads — Luiz Passaroni</title>
  <meta name="description" content="Arquivos disponibilizados por Luiz Passaroni.">
  <meta name="color-scheme" content="light dark">
  <link rel="stylesheet" href="../style.css">

  <style>
    .ios-widget-glass {
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.1) !important;
      border-radius: 1.5rem !important;
      background: rgba(255, 255, 255, 0.7);
      overflow: hidden;
    }

    @media (prefers-color-scheme: dark) {
      .ios-widget-glass {
        background: rgba(28, 28, 30, 0.75) !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
      }
    }

    .dl-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s ease;
    }

    .dl-item:last-child { border-bottom: none; }
    .dl-item:active { background: rgba(0, 0, 0, 0.04); }

    @media (prefers-color-scheme: dark) {
      .dl-item:active { background: rgba(255, 255, 255, 0.05); }
    }

    .dl-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      background: linear-gradient(135deg, #007AFF, #34AADC);
    }

    .dl-info { flex: 1; min-width: 0; }
    .dl-name { font-size: 15px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .dl-meta { font-size: 12px; margin-top: 2px; opacity: 0.5; }
    .dl-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .dl-arrow { width: 18px; height: 18px; opacity: 0.35; }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 15px;
      font-weight: 500;
      color: var(--ios-blue, #007AFF);
      text-decoration: none;
      padding: 6px 0;
      opacity: 0.9;
    }

    .section-group { display: flex; flex-direction: column; gap: 8px; }
    .category-label { font-size: 12px; font-weight: 600; text-transform: uppercase; opacity: 0.45; padding-left: 6px; }
    
    .empty-state { padding: 48px 24px; text-align: center; opacity: 0.5; }
  </style>
</head>

<body class="min-h-screen">
  <main class="flex-1 flex flex-col pt-8 pb-16">
    <section class="mx-auto w-full max-w-3xl px-4 space-y-6">

      <a href="../index.html" class="back-btn ios-tappable">
        <svg width="10" height="16" viewBox="0 0 10 16" fill="none">
          <path d="M8.5 1.5L1.5 8L8.5 14.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Luiz Passaroni
      </a>

      <div>
        <h1 class="ios-title1">Downloads</h1>
        <p class="ios-subheadline ios-text-secondary" style="margin-top: 4px;">
          Arquivos sincronizados do Google Drive.
        </p>
      </div>

      <div id="downloads-container" class="section-group">
        <div class="ios-widget-glass">
          <div class="empty-state">A carregar ficheiros...</div>
        </div>
      </div>

    </section>
  </main>

  <script>
    async function loadDownloads() {
      const container = document.getElementById('downloads-container');
      
      try {
        const response = await fetch('arquivos.json');
        if (!response.ok) throw new Error();
        const files = await response.json();

        if (files.length === 0) {
          container.innerHTML = `
            <div class="ios-widget-glass">
              <div class="empty-state">A pasta do Drive está vazia.</div>
            </div>`;
          return;
        }

        container.innerHTML = `
          <p class="category-label">Arquivos Disponíveis</p>
          <div class="ios-widget-glass">
            ${files.map(file => `
              <a href="${file.url}" target="_blank" class="dl-item ios-tappable">
                <div class="dl-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                  </svg>
                </div>
                <div class="dl-info">
                  <div class="dl-name">${file.name}</div>
                  <div class="dl-meta">${file.size || 'Google Drive'}</div>
                </div>
                <div class="dl-right">
                  <svg class="dl-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M7 13l5 5 5-5M12 18V6"/>
                  </svg>
                </div>
              </a>
            `).join('')}
          </div>`;
      } catch (e) {
        container.innerHTML = `
          <div class="ios-widget-glass">
            <div class="empty-state">
              Aguardando sincronização inicial...<br>
              <small style="font-size: 11px">Execute o workflow no GitHub Actions.</small>
            </div>
          </div>`;
      }
    }

    document.addEventListener('DOMContentLoaded', loadDownloads);
  </script>
</body>
</html>